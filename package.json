{
  "name": "ai-browser-plagin",
  "version": "0.0.0",
  "description": "AI-саммаризатор веб-страниц и PDF — браузерное расширение Manifest V3 (BYOK, без бэкенда)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@types/chrome": "^0.0.270",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "pdfjs-dist": "^5.6.205"
  }
}
